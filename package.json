{
  "name": "clinica",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.mjs",
  "scripts": {
    "dev": "vite --host",
    "dev:electron": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.mbai.clinica",
    "productName": "mbai sistemas",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/icons/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icons/clinica.ico",
      "signAndEditExecutable": false,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "shortcutName": "mbai sistemas"
    },
    "portable": {
      "artifactName": "mbai-sistemas-clinica-portable.exe"
    }
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.2",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.462.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.19",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^5.4.14",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-plugin-pwa": "^0.21.1"
  }
}
